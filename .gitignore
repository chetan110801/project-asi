# Project ASI ‚Äî this is a Markdown knowledge repo. Keep it clean.

# OS / filesystem cruft
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Editor / IDE
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*~

# Temp / backup files
*.tmp
*.bak
*.orig

# Local, private notes not meant for the shared history
# (use this prefix for anything you want to keep off GitHub)
LOCAL_*
*.local.md

# Purchased / copyrighted source material ‚Äî kept LOCAL only, never published.
# You drop bought PDFs/EPUBs here; I read them to write notes; git ignores them.
# (The folder's README is kept tracked so the structure is visible on GitHub.)
RESOURCES/library/*
!RESOURCES/library/README.md
*.pdf
*.epub
*.mobi
*.azw3

# (No build artifacts expected ‚Äî this repo is plain text by design.)

# 11GB local book/video collection ó NEVER commit (a backup copy exists elsewhere)
local_resources/
*.mp4
*.djvu
*.chm
